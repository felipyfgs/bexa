# Credenciais Ebinex (obrigatórias)
EBINEX_EMAIL=seu@email.com
EBINEX_PASSWORD=troque-esta-senha

# Ambiente da conta: TEST (padrão) ou REAL
BEXA_ENVIRONMENT=TEST

# Conta REAL: literal exato (não use 1/TRUE/YES genéricos)
# BEXA_ENVIRONMENT=REAL
# BEXA_ALLOW_REAL_TRADING=YES_REAL_TRADING

# Símbolo / timeframe padrão (aliases: BEXA_SYMBOL, BEXA_TIMEFRAME)
BEXA_DEFAULT_SYMBOL=IDXUSDT
BEXA_DEFAULT_TIMEFRAME=M1

# Diretório para sessão em arquivo (opcional; vazio = memória)
# BEXA_SESSION_DIR=

# Limites de risco na execução pontual
BEXA_MAX_INVESTMENT=10
# BEXA_CONNECT_TIMEOUT=15
# BEXA_SETTLEMENT_TIMEOUT=130
# BEXA_SETTLEMENT_BUFFER_SECONDS=20

# --- Gates CLI de ordem única (não ficam no Settings; só no comando) ---
# BEXA_ALLOW_DEMO_ORDER=YES_ONE_DEMO_ORDER
# BEXA_ALLOW_REAL_ORDER=YES_ONE_REAL_ORDER

# --- Robô automático (bexa run) ---
# Gate obrigatório + flag de enable (ambos necessários)
# BEXA_ALLOW_BOT=YES_RUN_BOT
# BEXA_BOT_ENABLED=YES
#
# Defaults seguros:
# BEXA_BOT_STRATEGY=hold
# BEXA_BOT_DRY_RUN=1
# BEXA_BOT_AUTO_TRADE=          # só YES_AUTO_TRADE (literal) habilita envio
# BEXA_BOT_INVESTMENT=1
# BEXA_BOT_MAX_TRADES=20
# BEXA_BOT_MAX_OPEN_ORDERS=1
# BEXA_BOT_COOLDOWN_SECONDS=5
# BEXA_BOT_MAX_DAILY_LOSS=0     # 0 = desligado
# BEXA_BOT_HISTORY_SIZE=50
# BEXA_BOT_WAIT_SETTLEMENT=1    # 0 = fire-and-forget avançado
#
# Auto-trade LIVE em REAL (extra, literal forte):
# BEXA_ALLOW_AUTO_REAL_TRADE=YES_AUTO_REAL_TRADE
